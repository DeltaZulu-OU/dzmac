<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="Dzmac.VerboseDiagnostics" value="false" />
    <add key="Dzmac.OuiCachePath" value="" />
    <add key="Dzmac.OuiEndpoint" value="https://standards-oui.ieee.org/oui/oui.txt" />
    <add key="Dzmac.OuiDownloadTimeoutSeconds" value="15" />
    <add key="Dzmac.OuiDownloadRetryCount" value="3" />
    <add key="Dzmac.AdminOperationTimeoutSeconds" value="20" />
    <add key="Dzmac.AdminOperationRetryCount" value="1" />
    <!-- Legacy aliases kept for one release cycle. -->
    <add key="DZMACLib.VerboseDiagnostics" value="false" />
    <add key="DZMACLib.OuiCachePath" value="" />
    <add key="DZMACLib.OuiEndpoint" value="https://standards-oui.ieee.org/oui/oui.txt" />
    <add key="DZMACLib.OuiDownloadTimeoutSeconds" value="15" />
    <add key="DZMACLib.OuiDownloadRetryCount" value="3" />
    <add key="DZMACLib.AdminOperationTimeoutSeconds" value="20" />
    <add key="DZMACLib.AdminOperationRetryCount" value="1" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2" />
    <!-- Let's disable auto-resizing for DPI changes -->
    <add key="EnableWindowsFormsHighDpiAutoResizing" value="false" />
    <add key="Toolstrip.DisableHighDpiImprovements" value="false" />
  </System.Windows.Forms.ApplicationConfigurationSection>
  <system.data>
  </system.data>
</configuration>
